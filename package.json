      "node18-win-x64"
    ]
  },
  "dependencies": {
    "active-win": "^8.1.0",
    "axios": "^1.6.7",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "pkg": "^5.8.1"
  }
}