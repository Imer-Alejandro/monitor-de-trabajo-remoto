{
  "name": "agente-monitoreo-remoto",
  "version": "1.0.0",
  "description": "Agente de monitoreo de jornadas remotas",
  "main": "Index.js",
  "scripts": {
    "start": "node Index.js",
    "dev": "nodemon Index.js",
    "build": "pkg Index.js --target node18-win-x64 --output dist/AgenteMonitoreo.exe --compress GZip"
  },
  "pkg": {
